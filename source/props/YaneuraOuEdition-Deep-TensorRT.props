<?xml version="1.0" encoding="utf-8"?>
<Project ToolsVersion="4.0" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <ImportGroup Label="PropertySheets" />
  <PropertyGroup Label="UserMacros">
    <YaneuraOuTarget>Deep-TensorRT</YaneuraOuTarget>
    <YaneuraOuDir>Deep-TensorRT</YaneuraOuDir>
  </PropertyGroup>
  <PropertyGroup>
    <OutDir>$(OutBaseDir)$(YaneuraOuDir)\</OutDir>
    <TargetName>$(ProjectName)-$(YaneuraOuTarget)</TargetName>
    <_PropertySheetDisplayName>YaneuraOuEdition-Deep-TensorRT</_PropertySheetDisplayName>
    <IncludePath>$(VC_IncludePath);$(WindowsSDK_IncludePath);C:\ProgramData\YaneuraOu\TensorRT-10.16.1.11\include;C:\Program Files\NVIDIA GPU Computing Toolkit\CUDA\v13.1\include</IncludePath>
    <LibraryPath>$(VC_LibraryPath_x64);$(WindowsSDK_LibraryPath_x64);C:\ProgramData\YaneuraOu\TensorRT-10.16.1.11\lib;C:\Program Files\NVIDIA GPU Computing Toolkit\CUDA\v13.1\lib\x64</LibraryPath>
  </PropertyGroup>
  <ItemDefinitionGroup>
    <ClCompile>
      <PreprocessorDefinitions>YANEURAOU_ENGINE_DEEP;TENSOR_RT;%(PreprocessorDefinitions)</PreprocessorDefinitions>
    </ClCompile>
    <Link>
      <AdditionalDependencies>kernel32.lib;user32.lib;gdi32.lib;winspool.lib;comdlg32.lib;advapi32.lib;shell32.lib;ole32.lib;oleaut32.lib;uuid.lib;odbc32.lib;odbccp32.lib;%(AdditionalDependencies);cudart.lib;nvinfer_10.lib;nvonnxparser_10.lib</AdditionalDependencies>
    </Link>
  </ItemDefinitionGroup>
  <ItemGroup>
    <BuildMacro Include="YaneuraOuTarget">
      <Value>$(YaneuraOuTarget)</Value>
    </BuildMacro>
    <BuildMacro Include="YaneuraOuDir">
      <Value>$(YaneuraOuDir)</Value>
    </BuildMacro>
  </ItemGroup>
  <ItemGroup>
    <Content Condition="Exists('C:\ProgramData\YaneuraOu\cudnn-windows-x86_64-9.23.0.39_cuda13-archive\bin\x86\cudnn_adv64_9.dll')" Include="C:\ProgramData\YaneuraOu\cudnn-windows-x86_64-9.23.0.39_cuda13-archive\bin\x86\cudnn_adv64_9.dll">
      <CopyToOutputDirectory>Always</CopyToOutputDirectory>
      <Visible>false</Visible>
    </Content>
    <Content Condition="Exists('C:\ProgramData\YaneuraOu\cudnn-windows-x86_64-9.23.0.39_cuda13-archive\bin\x86\cudnn_cnn64_9.dll')" Include="C:\ProgramData\YaneuraOu\cudnn-windows-x86_64-9.23.0.39_cuda13-archive\bin\x86\cudnn_cnn64_9.dll">
      <CopyToOutputDirectory>Always</CopyToOutputDirectory>
      <Visible>false</Visible>
    </Content>
    <Content Condition="Exists('C:\ProgramData\YaneuraOu\cudnn-windows-x86_64-9.23.0.39_cuda13-archive\bin\x86\cudnn_ops64_9.dll')" Include="C:\ProgramData\YaneuraOu\cudnn-windows-x86_64-9.23.0.39_cuda13-archive\bin\x86\cudnn_ops64_9.dll">
      <CopyToOutputDirectory>Always</CopyToOutputDirectory>
      <Visible>false</Visible>
    </Content>
    <Content Include="C:\ProgramData\YaneuraOu\TensorRT-10.16.1.11\bin\nvinfer_10.dll">
      <CopyToOutputDirectory>Always</CopyToOutputDirectory>
      <Visible>false</Visible>
    </Content>
    <Content Include="C:\ProgramData\YaneuraOu\TensorRT-10.16.1.11\bin\nvinfer_plugin_10.dll">
      <CopyToOutputDirectory>Always</CopyToOutputDirectory>
      <Visible>false</Visible>
    </Content>
    <Content Include="C:\ProgramData\YaneuraOu\TensorRT-10.16.1.11\bin\nvonnxparser_10.dll">
      <CopyToOutputDirectory>Always</CopyToOutputDirectory>
      <Visible>false</Visible>
    </Content>
  </ItemGroup>
</Project>